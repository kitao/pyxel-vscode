{
  "compilerOptions": {
    "esModuleInterop": true,
    "lib": ["ES2022"],
    "module": "commonjs",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022"
  },
  "exclude": ["dist", "node_modules", "src/__tests__"],
  "include": ["src"]
}
